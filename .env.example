# MongoDB connection
MONGODB_URI=mongodb://localhost:27017/afonsystem

# Application port
PORT=3000

# Set to "true" to seed fake data on startup (LGPD-safe demo mode)
# When true, no real GitLab connection is made
SEED_ON_START=true

# GitLab integration (only used when SEED_ON_START=false)
# GITLAB_URL=https://gitlab.example.com
# GITLAB_PAT=your_personal_access_token

# ─── LLM Provider for Semantic Analysis (Phase 3) ───────────────────────────
#
# Option 1: Local / OpenAI-compatible endpoint (Ollama, vLLM, llama.cpp, LM Studio)
#   Priority: used first if set.
LLM_BASE_URL=http://localhost:11434
SEMANTIC_MODEL=gemma3:27b
# LLM_API_KEY=                     # optional, only if your endpoint requires auth

# Option 2: Anthropic Claude API
# ANTHROPIC_API_KEY=sk-ant-...
# SEMANTIC_MODEL=claude-haiku-4-5-20251001
