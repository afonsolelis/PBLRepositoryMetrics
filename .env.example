# MongoDB connection
MONGODB_URI=mongodb://localhost:27017/afonsystem

# Application port
PORT=3000

# Set to "true" to seed fake data on startup (LGPD-safe demo mode)
# When true, no real GitLab connection is made
SEED_ON_START=true

# GitLab integration (only used when SEED_ON_START=false)
# GITLAB_URL=https://gitlab.example.com
# GITLAB_PAT=your_personal_access_token

# Anthropic API for semantic analysis (Phase 3)
# If not set, the system uses mock assessments based on structural checks
# ANTHROPIC_API_KEY=sk-ant-...

# LLM model for semantic analysis (default: claude-haiku-4-5-20251001)
# SEMANTIC_MODEL=claude-haiku-4-5-20251001
