<%- include('../partials/header') %>

<!-- Sprint Descriptor Banner -->
<% if (sprintDescriptor) { %>
<div class="alert alert-info mb-4">
  <div class="row align-items-center">
    <div class="col">
      <strong>Active Sprint Baseline (SCM)</strong> &mdash;
      <%= sprintDescriptor.sprint_id %>: <%= sprintDescriptor.title %>
      &bull; Partner: <%= sprintDescriptor.partner %>
      &bull; <%= sprintDescriptor.start_date %> → <%= sprintDescriptor.end_date %>
      &bull; <%= sprintDescriptor.working_days %> working days
    </div>
    <div class="col-auto">
      <span class="badge bg-primary">M<%= sprintDescriptor.module.replace('M','') %> Sprint <%= sprintDescriptor.sprint_number %></span>
    </div>
  </div>
</div>
<% } %>

<!-- Filters -->
<form method="GET" action="/" class="row g-2 mb-4" id="filterForm">
  <div class="col-md-4">
    <select name="project_id" class="form-select" onchange="this.form.submit()">
      <option value="">All Projects</option>
      <% projects.forEach(p => { %>
        <option value="<%= p.project_id %>" <%= query.project_id == p.project_id ? 'selected' : '' %>>
          <%= p.name %>
        </option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-2">
    <input type="date" name="from" class="form-control" value="<%= query.from || '' %>" placeholder="From">
  </div>
  <div class="col-md-2">
    <input type="date" name="to" class="form-control" value="<%= query.to || '' %>" placeholder="To">
  </div>
  <div class="col-md-2">
    <button type="submit" class="btn btn-primary w-100">Filter</button>
  </div>
  <div class="col-md-2">
    <a href="/" class="btn btn-outline-secondary w-100">Reset</a>
  </div>
</form>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card text-center">
      <div class="card-body">
        <div class="fs-2 fw-bold text-primary"><%= counts.projects %></div>
        <div class="text-muted small">Projects (Teams)</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center">
      <div class="card-body">
        <div class="fs-2 fw-bold text-success"><%= counts.commits %></div>
        <div class="text-muted small">Commits (Config Items)</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center">
      <div class="card-body">
        <div class="fs-2 fw-bold text-info"><%= counts.mrs %></div>
        <div class="text-muted small">Merge Requests</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center">
      <div class="card-body">
        <div class="fs-2 fw-bold text-warning"><%= counts.issues %></div>
        <div class="text-muted small">Issues</div>
      </div>
    </div>
  </div>
</div>

<!-- SCM Conformance Distance — Each team's distance from baseline (no ranking) -->
<div class="card mb-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <strong><i class="bi bi-shield-check me-2"></i>Artifact Conformance Distance from Baseline</strong>
    <small class="text-muted">Sprint M7-S3 · Each team evaluated independently</small>
  </div>
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-dark">
        <tr>
          <th>Team / Project</th>
          <th class="text-center">Score</th>
          <th class="text-center">Trend</th>
          <th class="text-center">Sprint Day</th>
          <th>CEP Patterns Detected</th>
          <th>Weak Points</th>
        </tr>
      </thead>
      <tbody>
        <% conformanceSummary.forEach(c => { %>
        <tr>
          <td>
            <a href="/projects/<%= c.project_id %>" class="fw-bold text-decoration-none">
              <%= c.name.replace(' — M7 Sprint 3','') %>
            </a>
            <br><small class="text-muted"><%= c.pattern %></small>
          </td>
          <td class="text-center">
            <% const pct = Math.round((c.score || 0) * 100); %>
            <span class="badge fs-6 bg-<%= pct >= 70 ? 'success' : pct >= 40 ? 'warning' : 'danger' %>">
              <%= pct %>%
            </span>
          </td>
          <td class="text-center">
            <% const icons = { improving: '↑', stable: '→', deteriorating: '↓' }; %>
            <% const colors = { improving: 'text-success', stable: 'text-secondary', deteriorating: 'text-danger' }; %>
            <span class="<%= colors[c.trend] || '' %> fw-bold"><%= icons[c.trend] || '—' %> <%= c.trend || '—' %></span>
          </td>
          <td class="text-center"><%= c.sprint_day || '—' %></td>
          <td>
            <% (c.patterns || []).forEach(pt => { %>
              <span class="badge bg-<%= pt === 'LOW_CADENCE' ? 'danger' : 'warning text-dark' %> me-1">
                <%= pt %>
              </span>
            <% }) %>
          </td>
          <td class="small text-danger">
            <% (c.weak_points || []).slice(0, 2).forEach(wp => { %>
              <div>• <%= wp.replace('[CRITICAL] ','').replace('[WARNING] ','') %></div>
            <% }) %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Conventional Commit Types as KPI cards -->
<% if (Object.keys(conventionalTypes).length > 0) { %>
<% const typeColors = { feat:'primary', fix:'danger', docs:'info', test:'success', refactor:'secondary', chore:'dark', ci:'warning', perf:'success', style:'secondary', build:'dark' }; %>
<div class="row g-2 mb-3">
  <div class="col-12"><small class="text-muted fw-bold">Commit Quality (Conventional Commits)</small></div>
  <% Object.entries(conventionalTypes).sort((a,b)=>b[1]-a[1]).forEach(([type, count]) => { %>
  <div class="col">
    <div class="card text-center border-0 bg-light">
      <div class="card-body py-2 px-1">
        <div class="fs-4 fw-bold text-<%= typeColors[type] || 'secondary' %>"><%= count %></div>
        <div class="text-muted" style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px"><%= type %></div>
      </div>
    </div>
  </div>
  <% }) %>
</div>
<% } %>

<!-- Team Artifact Charts — single row, line chart wider -->
<div class="row g-3 mb-4">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header small">Team Commits over Time</div>
      <div class="card-body p-2"><canvas id="commitsOverTimeChart" height="180"></canvas></div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card">
      <div class="card-header small">MR Status</div>
      <div class="card-body p-2 d-flex justify-content-center"><canvas id="mrStatusChart" style="max-height:150px;max-width:150px"></canvas></div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card">
      <div class="card-header small">Issue Status</div>
      <div class="card-body p-2 d-flex justify-content-center"><canvas id="issueStatusChart" style="max-height:150px;max-width:150px"></canvas></div>
    </div>
  </div>
</div>

<!-- Project list -->
<div class="card mb-4">
  <div class="card-header">Project List</div>
  <div class="list-group list-group-flush">
    <% projects.forEach(p => { %>
      <a href="/projects/<%= p.project_id %>" class="list-group-item list-group-item-action">
        <div class="d-flex justify-content-between">
          <span class="fw-bold"><%= p.name %></span>
          <small class="text-muted"><%= p.path_with_namespace %></small>
        </div>
        <small class="text-muted"><%= p.description %></small>
      </a>
    <% }) %>
  </div>
</div>

<script>
  // Pass filter query to chart fetcher
  const filterQuery = '<%= new URLSearchParams(query).toString() %>';
</script>

<%- include('../partials/footer') %>
