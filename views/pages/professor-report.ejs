<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="mb-0"><i class="bi bi-file-text me-2"></i>Professor Report</h4>
    <small class="text-muted"><%= project.name %></small>
  </div>
  <a href="/projects/<%= project.project_id %>" class="btn btn-outline-secondary btn-sm">&larr; Back to Project</a>
</div>

<div class="alert alert-info">
  <strong>About this report:</strong> The data below is provided as a <em>subsidy</em> for the professor/advisor.
  It contains raw per-member activity from the repository. No scores, no rankings, no automated judgments are applied.
  The complete evaluation of individual contributions is the exclusive prerogative of the professor.
</div>

<!-- Team totals -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card text-center"><div class="card-body">
      <div class="fs-2 fw-bold text-primary"><%= members.length %></div>
      <div class="text-muted small">Team Members</div>
    </div></div>
  </div>
  <div class="col-md-3">
    <div class="card text-center"><div class="card-body">
      <div class="fs-2 fw-bold text-success"><%= totals.commits %></div>
      <div class="text-muted small">Total Commits</div>
    </div></div>
  </div>
  <div class="col-md-3">
    <div class="card text-center"><div class="card-body">
      <div class="fs-2 fw-bold text-info"><%= totals.mrs %></div>
      <div class="text-muted small">Total MRs</div>
    </div></div>
  </div>
  <div class="col-md-3">
    <div class="card text-center"><div class="card-body">
      <div class="fs-2 fw-bold text-warning"><%= totals.issues %></div>
      <div class="text-muted small">Total Issues</div>
    </div></div>
  </div>
</div>

<!-- Per-member raw data -->
<% members.forEach(m => { %>
<div class="card mb-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span><strong><%= m.name %></strong> <small class="text-muted">@<%= m.username %></small></span>
    <div>
      <span class="badge bg-secondary me-1"><%= m.commit_count %> commits</span>
      <span class="badge bg-secondary me-1"><%= m.mr_count %> MRs</span>
      <span class="badge bg-secondary"><%= m.issue_count %> issues</span>
    </div>
  </div>
  <div class="card-body p-0">
    <% if (m.commits.length > 0) { %>
    <table class="table table-sm mb-0">
      <thead class="table-light"><tr><th>SHA</th><th>Message</th><th>Date</th></tr></thead>
      <tbody>
        <% m.commits.slice(0, 10).forEach(c => { %>
        <tr>
          <td><code class="small"><%= c.sha.substring(0,8) %></code></td>
          <td class="small"><%= c.message.substring(0, 70) %><%= c.message.length > 70 ? '...' : '' %></td>
          <td class="small text-muted"><%= c.committed_date.substring(0,10) %></td>
        </tr>
        <% }) %>
        <% if (m.commits.length > 10) { %>
        <tr><td colspan="3" class="small text-muted text-center">... and <%= m.commits.length - 10 %> more commits</td></tr>
        <% } %>
      </tbody>
    </table>
    <% } else { %>
    <div class="p-3 text-muted small">No commits recorded for this member in this sprint.</div>
    <% } %>
  </div>
</div>
<% }) %>

<%- include('../partials/footer') %>
